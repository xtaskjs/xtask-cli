{
  "name": "@xtaskjs/cli",
  "version": "0.1.5",
  "description": "Commander-based CLI for creating and scaffolding XTaskJS projects.",
  "type": "module",
  "bin": {
    "xtask": "./dist/xtask.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/xtask.ts",
    "dev": "tsx watch src/xtask.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage"
  },
  "keywords": [
    "xtaskjs",
    "commander",
    "cli",
    "typescript"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "tar": "^7.4.3"
  }
}